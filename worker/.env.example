# ── Vercel App URL ──
VERCEL_APP_URL=https://your-app.vercel.app

# ── Worker Authentication (same value as WORKER_SECRET in Vercel env vars) ──
WORKER_SECRET=your-random-secret-here

# ── Anthropic API Key (Claude サブスクリプションのAPIキー) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Polling Interval (ms) ──
POLL_INTERVAL=10000
