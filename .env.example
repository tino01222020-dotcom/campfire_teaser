# ── Vercel Storage (auto-configured when you add storage in Vercel Dashboard) ──
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# ── Cron Security ──
CRON_SECRET=your-random-secret-here

# ── DB Setup Key ──
SETUP_SECRET=crowdfuel-setup-2026

# ── Claude Worker Authentication ──
# ローカルワーカーとVercelの認証用シークレット（同じ値を両方に設定）
WORKER_SECRET=your-random-worker-secret

# ── All other credentials are stored in Vercel Postgres via Settings UI ──
# Users connect their own accounts through the dashboard:
#   Settings → LINE / SendGrid / Meta / Google Ads → Enter credentials → Save
